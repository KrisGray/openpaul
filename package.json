{
  "name": "openpaul",
  "version": "0.1.1",
  "description": "OpenPAUL - Plan-Apply-Unify Loop plugin for OpenCode",
  "type": "module",
  "main": "plugin.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./plugin.cjs"
    }
  },
  "files": [
    "dist",
    "plugin.cjs",
    "README.md",
    "src/commands",
    "src/templates",
    "src/references",
    "src/workflows",
    "src/rules"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "openpaul",
    "plan-apply-unify",
    "ai",
    "development",
    "planning",
    "structured-development"
  ],
  "author": "Chris Kahler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrisGray/openpaul.git"
  },
  "bugs": {
    "url": "https://github.com/KrisGray/openpaul/issues"
  },
  "homepage": "https://github.com/KrisGray/openpaul#readme",
  "engines": {
    "node": ">=16.7.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@opencode-ai/plugin": "^1.2.0",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "marked": "^17.0.5",
    "ts-jest": "^29.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsc && bun build src/index.ts --outdir dist --target node --bundle --format esm && bun build src/index.ts --target node --bundle --format cjs --outfile dist/index.cjs",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "npm run build && jest --config jest.config.e2e.js",
    "docs": "typedoc",
    "docs:ci": "typedoc --gitRevision $(git rev-parse HEAD)",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "openpaul": "./dist/cli.js"
  }
}
